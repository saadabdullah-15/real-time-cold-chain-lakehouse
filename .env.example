# Local-development credentials only. Copy this file to .env before starting.
KAFKA_VERSION=4.2.1
SCHEMA_REGISTRY_VERSION=8.2.2
FLINK_VERSION=2.1.3
ICEBERG_VERSION=1.11.0
POLARIS_VERSION=1.6.0
TRINO_VERSION=483
PROMETHEUS_VERSION=v3.13.1
GRAFANA_VERSION=13.0.3
POSTGRES_VERSION=17.6-alpine

KAFKA_BOOTSTRAP_SERVERS=kafka:29092
SCHEMA_REGISTRY_URL=http://schema-registry:8081

MINIO_ROOT_USER=coldchain_admin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1
MINIO_WAREHOUSE_BUCKET=coldchain-warehouse
MINIO_CHECKPOINT_BUCKET=flink-checkpoints

POSTGRES_DB=polaris
POSTGRES_USER=polaris
POSTGRES_PASSWORD=change-me-postgres-password

POLARIS_CLIENT_ID=root
POLARIS_CLIENT_SECRET=change-me-polaris-secret
POLARIS_REALM=POLARIS
POLARIS_CATALOG=coldchain

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# Keep at 1 for the initial demo. Set to 2 only during the documented savepoint evolution.
PIPELINE_SCHEMA_VERSION=1
FLINK_RESTORE_PATH=
